# Copy to `.env` and fill in. All VITE_* vars are exposed to the browser bundle
# (no server secrets here — only publishable/client-side values).

# Backend API base URL (falls back to http://localhost:5000/api/v1 when absent)
VITE_API_URL=http://localhost:5000/api/v1

# Razorpay publishable key id (client-side; safe to expose)
VITE_RAZORPAY_KEY_ID=

# --- Optional: analytics & error monitoring (no-op when left blank) ---

# Sentry DSN for error monitoring
VITE_SENTRY_DSN=

# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
VITE_GA4_ID=
